<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro
    name="mobile_fr3_duo_v0_2"
    params="robot_types
            hand
            ros2_control
            gazebo
            gazebo_effort
            use_fake_hardware
            fake_sensor_commands
            reduced_version
            robot_ips
            description_pkg
            connected_to
            use_arms
            no_prefix
            ee_id
            special_connection
            xyz_ee
            rpy_ee
            tcp_xyz
            tcp_rpy
            safety_distance
            with_sc
            is_async:=false
            thread_priority:=50">

    <xacro:include filename="$(find franka_description)/accessories/franka_head_v0_2/franka_head.xacro"/>
    <xacro:include filename="$(find franka_description)/accessories/franka_spine_v0_1/franka_spine.xacro"/>
    <xacro:include filename="$(find franka_description)/robots/common/franka_robot.xacro"/>
    <xacro:include filename="$(find franka_description)/robots/tmrv0_2/tmrv0_2.xacro"/>
    <xacro:include filename="$(find franka_description)/robots/mobile_fr3_duo_v0_2/mobile_fr3_duo.ros2_control.xacro"/>
    <xacro:include filename="$(find franka_description)/robots/fr3_duo/fr3_duo.xacro"/>

    <xacro:if value="${gazebo}">
      <xacro:property name="ros_control_flag_for_real_hardware" value="false"/>
    </xacro:if>
    <xacro:unless value="${gazebo}">
      <xacro:property name="ros_control_flag_for_real_hardware" value="${ros2_control}"/>
    </xacro:unless>

    <xacro:property name="arm_prefixes_list" value="${['left','right']}"/>

    <!-- Verify that the given robot types are first a mobile base and then arms -->
    <xacro:unless value="${robot_types_list[0] == 'tmrv0_2'}">
      <xacro:property
        name="_assert"
        value="${xacro.fatal('mobile_fr3_duo_v0_2: robot_types[0] must be tmrv0_2')}"
        lazy_eval="false"/>
    </xacro:unless>
    <xacro:if value="${robot_types_list[1] == 'tmrv0_2' or robot_types_list[2] == 'tmrv0_2'}">
      <xacro:property
        name="_assert"
        value="${xacro.fatal('mobile_fr3_duo_v0_2: robot_types[1] and/or robot_types[2] cannot be tmrv0_2. They need to be arms.')}"
        lazy_eval="false"/>
    </xacro:if>

    <!-- The mobile base -->
    <xacro:tmrv0_2
      mobile_robot_type="${robot_types_list[0]}"
      robot_ip="${robot_ips_list[0]}"
      ros2_control="${ros_control_flag_for_real_hardware}"
      use_fake_hardware="${use_fake_hardware}"
      fake_sensor_commands="${fake_sensor_commands}"
      reduced_version="${reduced_version}"
      gazebo="${gazebo}"
      is_async="${is_async}"
      thread_priority="${thread_priority}"/>

    <!-- Head and Spine -->
    <xacro:franka_spine parent="base_link"/>
    <xacro:head parent="fr3_duo_mount_mounting_point"/>

    <!-- The FR3 Duo Arms -->
    <xacro:property name="only_arm_robot_types_list" value="${robot_types_list[1:]}"/>
    <xacro:property name="only_arm_robot_ips_list" value="${robot_ips_list[1:]}"/>
    <xacro:fr3_duo
      name="fr3_duo"
      robot_types="${only_arm_robot_types_list}"
      hand="${hand}"
      ee_id="${ee_id}"
      special_connection="${special_connection}"
      xyz_ee="${xyz_ee}"
      rpy_ee="${rpy_ee}"
      tcp_xyz="${tcp_xyz}"
      tcp_rpy="${tcp_rpy}"
      safety_distance="${safety_distance}"
      with_sc="${with_sc}"
      ros2_control="${ros_control_flag_for_real_hardware}"
      gazebo="${gazebo}"
      gazebo_effort="${gazebo_effort}"
      use_fake_hardware="${use_fake_hardware}"
      fake_sensor_commands="${fake_sensor_commands}"
      robot_ips="${only_arm_robot_ips_list}"
      description_pkg="${description_pkg}"
      base_mount="franka_spine_mounting_point"
      connected_to="${connected_to}"
      arm_prefixes="${arm_prefixes_list}"
      is_async="${is_async}"
      thread_priority="${thread_priority}"/>

    <xacro:if value="${gazebo}">
      <xacro:mobile_fr3_duo_ros2_control
        mobile_robot_type="tmrv0_2"
        robot_types="${robot_types_list}"
        arm_prefixes="${arm_prefixes_list}"
        robot_ips="${robot_ips_list}"
        hand="${hand}"
        use_fake_hardware="${use_fake_hardware}"
        fake_sensor_commands="${fake_sensor_commands}"
        gazebo="${gazebo}"
        gazebo_effort="${gazebo_effort}"
        robot_namespace=""/>
    </xacro:if>

  </xacro:macro>
</robot>
